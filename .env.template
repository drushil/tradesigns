# ============================================================
# TRADING AGENT — ENVIRONMENT CONFIGURATION
# 1. Copy: cp .env.template .env
# 2. Fill in your values below
# 3. NEVER commit .env (it's in .gitignore)
# ============================================================

# ── BROKER (Alpaca Paper Trading — free) ──────────────────
# Sign up: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true
USE_BRACKET_ORDERS=true
# Live trading requires BOTH ALPACA_PAPER=false and ENABLE_LIVE_TRADING=true.
ENABLE_LIVE_TRADING=false

# ── AI BRAIN (Groq API — primary, free tier) ─────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Signal decisions (strong JSON): llama-3.3-70b-versatile
# Set to llama-3.1-8b-instant to roll back quickly if 70b is rate-limited.
GROQ_DECISION_MODEL=llama-3.3-70b-versatile
# Shadow/A-B decision is logged only; it never changes execution.
LLM_SHADOW_DECISION_ENABLED=true
GROQ_SHADOW_DECISION_MODEL=llama-3.1-8b-instant
# Weekly digest model.
GROQ_DIGEST_MODEL=llama-3.3-70b-versatile
# Optional: Anthropic key kept here for future use only — not required.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── DATABASE (Supabase — free tier) ──────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://crxrnmmvrbwhqulyehmo.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxx          # anon/public key — used by dashboard (read-only)
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxx       # service_role key — used by agent (writes). NEVER expose to frontend.

# ── NEWS (NewsAPI — free 100 req/day) ────────────────────
# Get from: https://newsapi.org
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NOTIFICATIONS (Discord / Telegram — free) ────────────
# Discord: Server → Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxx/xxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── RISK PROFILE ─────────────────────────────────────────
# Options: conservative | cautious | moderate | growth | aggressive
RISK_PROFILE=moderate

# ── INVESTMENT HORIZON ────────────────────────────────────
# Options: short (mins-hours) | mid/swing (days) | both
INVESTMENT_HORIZON=both

# ── TRADING UNIVERSE ──────────────────────────────────────
TICKER_UNIVERSE=SPY,QQQ,GLD,TLT,AAPL
SWING_TICKERS=XLE,GLD,TLT,IBIT

# ── STARTING CAPITAL (paper) ─────────────────────────────
STARTING_CAPITAL_EUR=3000
TRADING_CAPITAL_EUR=3000
MAX_NOTIONAL_PER_TRADE_EUR=5000
# Hard ceiling: agent never deploys more than this regardless of Alpaca
# account balance (Alpaca paper accounts default to $100,000).
MAX_CAPITAL_DEPLOYED_EUR=3000
# EUR/USD conversion rate used for ceiling → USD. Update periodically
# or wire to a live FX feed when going live.
EURUSD_RATE=1.08

# Intraday margin guard (replaces the retired PDT rule, June 2026). Rejects an
# order whose USD notional exceeds usable buying power = buying_power * (1 - buffer).
INTRADAY_MARGIN_GUARD_ENABLED=true
INTRADAY_BUYING_POWER_BUFFER_PCT=10
MIN_BUYING_POWER_AFTER_ORDER_USD=0

# ── AGENT BEHAVIOUR ──────────────────────────────────────
LLM_CALLS_PER_HOUR_LIMIT=20

# ── LEARNING / EV ────────────────────────────────────────
LEARNING_LOOKBACK_DAYS=120
MIN_TRADES_TO_UPDATE=15
EV_MIN_SAMPLE_SIZE=8
EV_SHRINKAGE_TRADES=20
EV_MIN_NET_PCT=0.03
EV_ALLOW_EXPLORATION=true

# ── SWING / MACRO ────────────────────────────────────────
SWING_REEVAL_UTC_HOUR=14
SWING_REEVAL_UTC_MINUTE=0
SWING_REEVAL_WINDOW_MINUTES=5
SWING_HOLD_DAYS=3
SWING_MIN_SCORE=0.25
GEO_NEWS_BASELINE_24H=1.0

# ── LEARNED INTRADAY HOLD EXTENSION ─────────────────────
# Applies to all tickers only when conviction and composite score are strong.
LEARNED_HOLD_EXTENSION_ENABLED=true
LEARNED_HOLD_MIN_CONVICTION=0.80
LEARNED_HOLD_MIN_SIGNAL_SCORE=0.35
LEARNED_HOLD_MIN_MINUTES=120
LEARNED_HOLD_MAX_MINUTES=240

# ── HOLD DEADLINE DECISIONS ─────────────────────────────
HOLD_EXTENSION_MINUTES=30
HOLD_EXTENSION_MAX_COUNT=2
HOLD_EXTENSION_MIN_PNL_PCT=0.05
HOLD_EXTENSION_MIN_SIGNAL_SCORE=0.20
HOLD_EXTENSION_FADE_SCORE=0.10
TIME_EXIT_COOLDOWN_MINUTES=60

# ── END-OF-DAY INTRADAY CLEANUP ─────────────────────────
EOD_INTRADAY_CLEANUP_ENABLED=true
EOD_CLEANUP_BUFFER_MINUTES=30

# ── BROKER ENVIRONMENT ───────────────────────────────────
# Controls simulation vs live execution.
# Values: alpaca_paper | ibkr_live
# NEVER set ibkr_live until backend/broker/ibkr.py is built and tested.
BROKER_ENV=alpaca_paper
AUTO_TRADE_ENABLED=true

# ── ADVISORY-AUTO (separate paper account) ───────────────
# Separate Alpaca paper account for advisory-auto executor.
# Falls back to ALPACA_API_KEY / ALPACA_SECRET_KEY if not set.
# Keep dry-run enabled as the advisory control group. Set
# ADVISORY_AUTO_PAPER_EXECUTION=true to add Alpaca paper bracket orders without
# disabling dry-run/simulator measurement.
ADVISORY_AUTO_ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ADVISORY_AUTO_ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADVISORY_AUTO_CAPITAL_EUR=20000
ADVISORY_AUTO_MAX_POSITIONS=3
ADVISORY_AUTO_DAILY_LOSS_EUR=-500
ADVISORY_AUTO_ALLOC_A_PLUS=100
ADVISORY_AUTO_ALLOC_A=70
ADVISORY_AUTO_ALLOC_B=50
ADVISORY_AUTO_MAX_SIGNAL_AGE_MIN=5
ADVISORY_AUTO_DRY_RUN=true
ADVISORY_AUTO_PAPER_EXECUTION=false

# ── CASH SWEEP ───────────────────────────────────────────
# Nightly: park idle cash in a money-market ETF after US close.
# alpaca_paper uses SGOV; ibkr_live uses XEON (EU MMF).
SWEEP_TICKER=SGOV
SWEEP_MIN_EUR=500
SWEEP_RESERVE_PCT=25
SWEEP_FREQUENCY=nightly

# ── DIVIDEND SCANNER ─────────────────────────────────────
# Scans ticker universe for ex-dividend dates 1–5 days away.
# Advisory only — amplifies composite score slightly when ex-date is near.
DIVIDEND_SCAN_ENABLED=true
DIVIDEND_MIN_YIELD_PCT=1.5
